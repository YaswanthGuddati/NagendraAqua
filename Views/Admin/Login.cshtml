@model NagendraAqua.Models.Admin
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - Nagendra Aqua Feeds</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
        }

        /* ===== BACKGROUND WITH OVERLAY ===== */
        .bg-image {
            background: url('/Images/HomeBackG.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100%;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

            .bg-image::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(11, 29, 58, 0.7); /* Deep blue overlay */
                z-index: 1;
            }

        /* ===== GLASSMORPHISM LOGIN CARD ===== */
        .login-card {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.95);
            padding: 25px;
            width: 100%;
            max-width: 320px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            text-align: center;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.3);
        }

        .logo {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            margin-bottom: 15px;
            border: 2px solid #2b4378;
            padding: 2px;
            background: white;
        }

        .login-card h4 {
            font-weight: 700;
            color: #2b4378;
            margin-bottom: 15px;
            letter-spacing: 1px;
            font-size: 18px;
        }

        /* ===== FORM STYLING ===== */
        .form-group {
            position: relative;
            margin-bottom: 20px;
        }

            .form-group i {
                position: absolute;
                left: 15px;
                top: 40px;
                color: #2b4378;
            }

        .form-control {
            padding-left: 40px;
            height: 40px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            .form-control:focus {
                box-shadow: 0 0 0 0.25rem rgba(43, 67, 120, 0.15);
                border-color: #2b4378;
            }

        .btn-login {
            background-color: #2b4378;
            border: none;
            height: 45px;
            color: white;
            width: 100%;
            font-weight: 600;
            border-radius: 8px;
            transition: 0.3s;
            margin-top: 10px;
        }

            .btn-login:hover {
                background-color: #ff9800; /* Subtle brand accent on hover */
                color: white;
                transform: translateY(-2px);
            }

        .back-home {
            margin-top: 20px;
            display: inline-block;
            text-decoration: none;
            color: #666;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .back-home:hover {
                color: #2b4378;
                font-weight: 600;
            }

        /* Mobile Adjustments */
        @@media (max-width: 480px) {
            .login-card {
                margin: 20px;
                padding: 30px 20px;
            }
        }
    </style>
</head>

<body>

    <div class="bg-image">
        <div class="login-card">

            <img src="~/Images/Logohome.jpg" class="logo" alt="Nagendra Aqua Logo" />

            <h4>ADMIN PORTAL</h4>

            @using (Html.BeginForm("Login", "Admin", FormMethod.Post))
            {
                if (ViewBag.LoginError != null && ViewData.ModelState.IsValid)
                {
                    <div class="text-danger small mb-2">
                        @ViewBag.LoginError
                    </div>
                }

                <div class="form-group text-start">
                    <label class="form-label fw-bold small">User Name</label>
                    <i class="fas fa-user"></i>
                    @Html.TextBoxFor(m => m.SellerName,
                        new { @class = "form-control", placeholder = "Enter Username" })
                    @Html.ValidationMessageFor(m => m.SellerName, "", new { @class = "text-danger small" })
                </div>

                <div class="form-group text-start">
                    <label class="form-label fw-bold small">Password</label>
                    <i class="fas fa-lock"></i>
                    @Html.PasswordFor(m => m.Password,
                        new { @class = "form-control", placeholder = "Enter Password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <button type="submit" class="btn btn-login shadow-sm">
                    SIGN IN
                </button>
            }

            <a href="@Url.Action("Index","Home")" class="back-home">
                <i class="fas fa-arrow-left me-1"></i> Return to Website
            </a>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>